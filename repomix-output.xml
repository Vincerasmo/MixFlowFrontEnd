import { Input } from "@/components/ui/input";
import {
  Dialog,
  DialogContent,
  DialogHeader,
  DialogTitle,
  DialogFooter,
  DialogClose,
} from "@/components/ui/dialog";
import { getActiveSession } from "@/services/sessions";
import {
  getActiveMatches,
  getCompletedMatches,
  recordMatchResult,
  smartMixCourt,
  getQueue,
  getNextUpMatches,
} from "@/services/matches";
